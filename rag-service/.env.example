# Copy to .env and paste your Gemini API key in (https://aistudio.google.com/apikey).
# Without it the service still runs: uploads work, and /generate-tutorial returns
# a clearly-labelled offline tutorial built from the PDF's own sentences.
GOOGLE_API_KEY="your-key-here"

# Optional. Picture generation tries Gemini first, but Gemini's image models
# need billing enabled (the free AI Studio tier has zero image-gen quota), so
# it falls back to pollinations.ai, which works with no key at all. Set this
# only if you have a pollinations.ai API token (https://pollinations.ai) and
# want its higher-priority/rate-limited tier instead of the anonymous one.
POLLINATIONS_API_KEY=""
