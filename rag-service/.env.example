# Copy to .env and paste your Gemini API key in (https://aistudio.google.com/apikey).
# Without it the service still runs: uploads work, and /generate-tutorial returns
# a clearly-labelled offline tutorial built from the PDF's own sentences.
GOOGLE_API_KEY="your-key-here"

# Primary text-generation key (https://console.groq.com/keys) - tried before
# Gemini everywhere text is generated (tutorials, curriculum, quizzes). Free
# tier is far more generous than Gemini's (1,000 req/day vs ~20/day), and
# also covers TTS (canopylabs/orpheus-v1-english) once its terms are
# accepted at https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english
# - falls back to Gemini automatically either way. Groq has no image
# generation or embeddings, so GOOGLE_API_KEY is still needed for those.
GROQ_API_KEY="your-key-here"

# PRIMARY source for unit/tutorial/VISUAL-mode pictures (https://unsplash.com/developers).
# Tried before the image generators because it's dramatically faster (a single
# search call vs. waiting on image synthesis) and costs no storage - the photo
# is hotlinked from Unsplash's CDN, which is also what their API guidelines
# require (don't re-host their images). Free tier: 50 requests/hour demo, 5,000/hour
# once your app is approved for production. Only the ACCESS key is used at
# runtime; the SECRET key is only needed for the OAuth flow (user-authenticated
# actions like liking a photo), which this app doesn't do - it's here so the
# pair stays together if that's ever added.
UNSPLASH_ACCESS_KEY="your-key-here"
UNSPLASH_SECRET_KEY="your-key-here"

# Note: pollinations.ai was removed as an image source - it generated each
# picture on demand (slow) and throttled under a curriculum-sized burst.
# Unsplash above is now the image source; GOOGLE_API_KEY's Gemini image model
# is only a last resort for topics Unsplash has no photo for, and does nothing
# unless that key's project has image-generation billing enabled.

# Background job queue (docker-compose sets these for you automatically -
# only needed if running the FastAPI app or `celery worker` outside Docker).
REDIS_URL=redis://localhost:6379/0
BACKEND_INTERNAL_URL=http://localhost:5001
INTERNAL_API_SECRET=change_this_dev_secret

# No key needed for YouTube transcript -> quiz generation - it uses the free
# youtube-transcript-api library (talks directly to YouTube's own public
# caption endpoint), not a paid third-party API.
