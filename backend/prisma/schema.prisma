generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEACHER
  STUDENT
}

enum TeacherStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum LearningMode {
  TEXT
  AUDIO
  VISUAL
  AR
}

enum SubscriptionPlan {
  MONTH_1
  MONTH_3
  MONTH_6
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IndexStatus {
  NOT_INDEXED
  PROCESSING
  READY
  FAILED
}

// ---------------------------------------------------------------------------
// Full-curriculum background generation pipeline
// ---------------------------------------------------------------------------

enum JobStage {
  QUEUED
  EXTRACTING
  PLANNING
  GENERATING_TEXT
  GENERATING_VISUALS
  GENERATING_AUDIO
  GENERATING_QUESTIONS
  FINALIZING
  COMPLETED
  FAILED
}

enum NotificationType {
  GENERATION_COMPLETE
  GENERATION_FAILED
}

enum YoutubeQuizStatus {
  QUEUED
  FETCHING_TRANSCRIPT
  GENERATING_QUESTIONS
  READY
  FAILED
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  role           Role           @default(STUDENT)
  // teacher-only fields - null for ADMIN/STUDENT
  teacherStatus  TeacherStatus?
  teacherNote    String?
  rememberMe     Boolean        @default(false)
  resetToken     String?
  resetTokenExp  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  demoResult      DemoResult?
  subscription    Subscription?
  quizSessions    QuizSession[]

  // teacher side
  classroomTaught Classroom?              @relation("TeacherClassroom")
  uploadedDocs    SyllabusDocument[]      @relation("UploadedBy")

  // student side
  enrolments      Enrolment[]             @relation("StudentEnrolments")
  joinRequests    ClassroomJoinRequest[]  @relation("StudentJoinRequests")
  attempts        AssessmentAttempt[]
  tutorials       Tutorial[]
  progress        StudentProgress?

  // Full-curriculum pipeline (student side)
  tutorialProgresses      TutorialProgress[]
  knowledgeCheckAttempts  KnowledgeCheckAttempt[]
  finalAssessmentAttempts FinalAssessmentAttempt[]
  rawDocProgress          RawDocProgress[]

  // Full-curriculum pipeline (teacher side)
  generationJobs  TutorialGenerationJob[]
  notifications   Notification[]
  youtubeQuizzes  YoutubeQuiz[]
}

model DemoResult {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  textEngagement   Float        @default(0)
  audioEngagement  Float        @default(0)
  visualEngagement Float        @default(0)
  arRecommended    Boolean      @default(false)
  preferredMode    LearningMode @default(TEXT)
  completedAt      DateTime     @default(now())
}

model Subscription {
  id            String           @id @default(cuid())
  userId        String           @unique
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan
  paymentStatus PaymentStatus    @default(PENDING)
  paymentMethod String           @default("eSewa")
  transactionId String?
  startDate     DateTime?
  expiryDate    DateTime?
  createdAt     DateTime         @default(now())
}

model QuizQuestion {
  id           String       @id @default(cuid())
  subject      String
  question     String
  options      Json
  answer       String
  imageUrl     String?
  audioText    String?
  learningMode LearningMode
  difficulty   Int          @default(1)
  ageGroup     String       @default("all")
  createdAt    DateTime     @default(now())
}

model LearningMaterial {
  id           String       @id @default(cuid())
  title        String
  subject      String
  type         String
  content      Json
  learningMode LearningMode
  createdAt    DateTime     @default(now())
}

model QuizSession {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentMode    LearningMode @default(TEXT)
  questionIndex  Int          @default(0)
  score          Int          @default(0)
  engagementLog  Json         @default("[]")
  completed      Boolean      @default(false)
  startedAt      DateTime     @default(now())
  completedAt    DateTime?
}

// ---------------------------------------------------------------------------
// Assessment history (PLAN.md Part 6) - AssessmentAttempt is the source of
// truth. DemoResult above is kept as a cheap "latest snapshot" cache; nothing
// new reads it as the source of truth.
// ---------------------------------------------------------------------------

model AssessmentAttempt {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  textEngagement     Float        @default(0)
  audioEngagement    Float        @default(0)
  visualEngagement   Float        @default(0)
  attentionSpanScore Float        @default(0) // focusedSamples / totalSamples * 100
  adaptationCount    Int          @default(0) // number of mode-switches during this attempt
  preferredMode      LearningMode @default(TEXT)
  arRecommended      Boolean      @default(false)

  scoreCorrect  Int    @default(0)
  scoreTotal    Int    @default(0)
  scorePercent  Float  @default(0)

  engagementLog Json      @default("[]")
  answerLog     Json      @default("[]")
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  durationSeconds Int?

  @@index([userId, completedAt])
}

// ---------------------------------------------------------------------------
// Classroom system (PLAN.md Part 5)
// ---------------------------------------------------------------------------

model Classroom {
  id          String   @id @default(cuid())
  name        String
  description String?
  teacherId   String   @unique // one teacher -> one classroom for now; drop @unique to allow many
  teacher     User     @relation("TeacherClassroom", fields: [teacherId], references: [id], onDelete: Cascade)

  admissionCriteria AdmissionCriteria?
  subjects          Subject[]
  enrolments        Enrolment[]
  joinRequests      ClassroomJoinRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdmissionCriteria {
  id          String    @id @default(cuid())
  classroomId String    @unique
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  minTextEngagement     Float?
  maxTextEngagement     Float?
  minAudioEngagement    Float?
  maxAudioEngagement    Float?
  minVisualEngagement   Float?
  maxVisualEngagement   Float?
  preferredModes        Json?   // e.g. ["VISUAL", "AUDIO"]
  minAttentionSpanScore Float?
  maxAttentionSpanScore Float?
  minScorePercent       Float?
  maxScorePercent       Float?
  arRecommendedOnly     Boolean?

  updatedAt DateTime @updatedAt
}

model Enrolment {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId   String
  student     User      @relation("StudentEnrolments", fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt    DateTime  @default(now())

  @@unique([classroomId, studentId])
}

model ClassroomJoinRequest {
  id           String            @id @default(cuid())
  classroomId  String
  classroom    Classroom         @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  studentId    String
  student      User              @relation("StudentJoinRequests", fields: [studentId], references: [id], onDelete: Cascade)
  matchScore   Float
  matchReasons Json
  status       JoinRequestStatus @default(PENDING)
  teacherNote  String?
  requestedAt  DateTime          @default(now())
  decidedAt    DateTime?

  @@unique([classroomId, studentId])
}

// ---------------------------------------------------------------------------
// RAG / syllabus (PLAN.md Part 7)
// ---------------------------------------------------------------------------

model Subject {
  id          String    @id @default(cuid())
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)
  name        String
  units       Unit[]
  createdAt   DateTime  @default(now())
}

model Unit {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  order       Int      @default(0)

  documents   SyllabusDocument[]
  tutorials   Tutorial[]
  preview     UnitPreview?

  // Full-curriculum pipeline - one canonical curriculum per unit, shared
  // across students (PLAN §23: canonical content + adaptive presentation,
  // not a separate generated copy per student)
  curriculum       TutorialCurriculum?
  generationJobs   TutorialGenerationJob[]

  ragUnitId   Int?         @unique // the integer id rag-service indexes under
  indexStatus IndexStatus  @default(NOT_INDEXED)
  createdAt   DateTime     @default(now())
}

// The "set up immediately on upload" artifact: one generic (no student
// diagnosis) tutorial text + generated image per unit, kicked off the moment
// indexing finishes so there's an instant placeholder before any specific
// student's personalized Tutorial exists.
model UnitPreview {
  id               String      @id @default(cuid())
  unitId           String      @unique
  unit             Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  tutorialText     String?
  visualSuggestion String?
  imageUrl         String?
  status           IndexStatus @default(NOT_INDEXED)
  errorMessage     String?
  updatedAt        DateTime    @updatedAt
}

model SyllabusDocument {
  id           String      @id @default(cuid())
  unitId       String
  unit         Unit        @relation(fields: [unitId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User        @relation("UploadedBy", fields: [uploadedById], references: [id])
  filename     String
  fileType     String
  storagePath  String
  pageCount    Int?
  chunkCount   Int?
  status       IndexStatus @default(NOT_INDEXED)
  errorMessage String?
  uploadedAt   DateTime    @default(now())

  generationJobs TutorialGenerationJob[]
  rawDocProgress RawDocProgress[]
}

// A student reading the ORIGINAL uploaded PDF (the "raw docs" door, distinct
// from the generated tutorial). Just a resume pointer - which page they left
// off on - so Back-then-return continues where they were.
model RawDocProgress {
  id         String           @id @default(cuid())
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  documentId String
  document   SyllabusDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  lastPage   Int              @default(1)
  updatedAt  DateTime         @updatedAt

  @@unique([studentId, documentId])
  @@index([studentId])
}

model Tutorial {
  id               String       @id @default(cuid())
  unitId           String
  unit             Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  studentId        String
  student          User         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  learningMode     LearningMode
  level            Int
  tutorialText     String
  audioScript      String
  visualSuggestion String
  imageUrl         String? // populated once Gemini image-gen finishes; null while pending/unavailable
  steps            Json    @default("[]")
  quiz             Json
  teacherNote      String
  sourceChunks     Int     @default(0)
  offline          Boolean @default(false)
  createdAt        DateTime @default(now())

  @@unique([studentId, unitId, learningMode, level])
  @@index([studentId, unitId])
}

// ---------------------------------------------------------------------------
// Gamification (PLAN.md Part 9)
// ---------------------------------------------------------------------------

model StudentProgress {
  id             String    @id @default(cuid())
  studentId      String    @unique
  student        User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  xp             Int       @default(0)
  streakDays     Int       @default(0)
  lastActiveDate DateTime?
  badges         Json      @default("[]") // [{id, name, earnedAt}]
  updatedAt      DateTime  @updatedAt
}

// ---------------------------------------------------------------------------
// Full-curriculum background generation pipeline (TODO.md Phases 1-10)
//
// A teacher's upload produces exactly one canonical TutorialCurriculum per
// Unit - generated once, in the background, shared by every student (PLAN
// §23: "canonical tutorial + adaptive presentation" rather than a full copy
// per student). TutorialProgress is the thin per-student pointer into it.
//
// The existing student-scoped Tutorial model (TEXT/AUDIO/VISUAL mode picker,
// generated lazily on first view) is left untouched for backward
// compatibility - a Unit routes to the new curriculum player only once its
// TutorialCurriculum exists; older/in-flight units keep working exactly as
// before.
// ---------------------------------------------------------------------------

model TutorialGenerationJob {
  id               String            @id @default(cuid())
  unitId           String
  unit             Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  sourceDocumentId String?
  sourceDocument   SyllabusDocument? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  teacherId        String
  teacher          User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  stage           JobStage @default(QUEUED)
  progressPercent Int      @default(0)
  errorMessage    String?
  retryCount      Int      @default(0)
  celeryTaskId    String? // the Celery task id, for correlating worker logs

  startedAt   DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  @@index([unitId])
  @@index([teacherId])
}

model TutorialCurriculum {
  id     String @id @default(cuid())
  unitId String @unique
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
  title  String

  lessons                  TutorialLesson[]
  finalAssessmentQuestions FinalAssessmentQuestion[]
  progresses               TutorialProgress[]
  finalAssessmentAttempts  FinalAssessmentAttempt[]

  sourceChunks Int      @default(0) // total chunks the source document produced
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TutorialLesson {
  id           String             @id @default(cuid())
  curriculumId String
  curriculum   TutorialCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  order        Int

  title       String
  explanation String
  example     String?
  imageUrl    String?
  audioUrl    String?

  // Traceability back to the source document (TODO.md §22 RAG compatibility)
  sourceChunkStart Int?
  sourceChunkEnd   Int?

  knowledgeCheck KnowledgeCheckQuestion?
  createdAt      DateTime                @default(now())

  @@unique([curriculumId, order])
  @@index([curriculumId])
}

model KnowledgeCheckQuestion {
  id       String         @id @default(cuid())
  lessonId String         @unique
  lesson   TutorialLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  question String
  options  Json // string[]
  correct  String

  attempts KnowledgeCheckAttempt[]
}

// One row per student per question - a retry overwrites rather than
// accumulates history, matching the existing Tutorial model's "cache the
// latest, don't keep a full history" convention.
model KnowledgeCheckAttempt {
  id         String                 @id @default(cuid())
  questionId String
  question   KnowledgeCheckQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  studentId  String
  student    User                   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  answer     String
  correct    Boolean
  answeredAt DateTime @default(now())

  @@unique([questionId, studentId])
  @@index([studentId])
}

model FinalAssessmentQuestion {
  id           String             @id @default(cuid())
  curriculumId String
  curriculum   TutorialCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  order        Int

  question String
  options  Json // string[]
  correct  String

  @@unique([curriculumId, order])
  @@index([curriculumId])
}

model FinalAssessmentAttempt {
  id           String             @id @default(cuid())
  curriculumId String
  curriculum   TutorialCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  studentId    String
  student      User               @relation(fields: [studentId], references: [id], onDelete: Cascade)

  answerLog    Json // [{questionId, answer, correct}]
  scoreCorrect Int
  scoreTotal   Int
  completedAt  DateTime @default(now())

  @@index([studentId, curriculumId])
}

// Per-student pointer into the canonical curriculum - not a content copy.
model TutorialProgress {
  id                 String             @id @default(cuid())
  studentId          String
  student            User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  curriculumId       String
  curriculum         TutorialCurriculum @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  currentLessonOrder Int                @default(0)
  // Which presentation the student last used (TEXT/AUDIO/VISUAL/AR). Purely a
  // display preference over the one shared curriculum - switching it never
  // regenerates content, and progress is kept whichever mode they pick.
  preferredMode      LearningMode       @default(TEXT)
  completed          Boolean            @default(false)
  completedAt        DateTime?
  updatedAt          DateTime           @updatedAt

  @@unique([studentId, curriculumId])
}

model Notification {
  id        String           @id @default(cuid())
  teacherId String
  teacher   User             @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String
  unitId    String?
  jobId     String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([teacherId, read])
}

// ---------------------------------------------------------------------------
// YouTube transcript -> quiz generation (TODO.md Phase 11)
// ---------------------------------------------------------------------------

model YoutubeQuiz {
  id           String            @id @default(cuid())
  teacherId    String
  teacher      User              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sourceUrl    String
  videoId      String
  status       YoutubeQuizStatus @default(QUEUED)
  errorMessage String?
  title        String?
  questions    YoutubeQuizQuestion[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model YoutubeQuizQuestion {
  id       String      @id @default(cuid())
  quizId   String
  quiz     YoutubeQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  order    Int
  question String
  options  Json // string[]
  correct  String

  @@unique([quizId, order])
}
